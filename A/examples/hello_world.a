// Hello World 示例
print("Hello, Nova!");

// 变量声明
var x = 10;
var y = 3.14;
var z = true;
var s = "Hello, Nova!";

// 打印变量
print("x =", x);
print("y =", y);
print("z =", z);
print("s =", s);

// 表达式
var result = x + 5;
print("x + 5 =", result);

// 条件语句
if (x > 5) {
    print("x is greater than 5");
} else {
    print("x is less than or equal to 5");
}

// 循环语句
for (int i = 0; i < 5; i++) {
    print("i =", i);
}

// 函数定义
function add(int a, int b) {
    return a + b;
}

// 函数调用
var sum = add(5, 3);
print("5 + 3 =", sum);